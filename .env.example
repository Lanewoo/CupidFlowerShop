# Copy to .env.local. Use a long random string for signing login cookies (JWT).
AUTH_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Staff dashboard is not linked from the public header. Open it directly in the browser, e.g.
#   http://localhost:3000/zh/admin
# You will be redirected to /zh/admin/login when not signed in. Default dev account is created in data/users.json (username admin / password admin unless changed).
